# Zerodha Kite Connect Credentials
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret

# Zerodha Login Credentials for Automated TOTP Login
KITE_USER_ID=your_zerodha_user_id
KITE_PASSWORD=your_zerodha_password
KITE_TOTP_SECRET=your_zerodha_totp_secret_key

# Email Report Settings
GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
REPORT_RECIPIENT=your@gmail.com

# Trading mode: paper or live
TRADING_MODE=paper

# Capital management
MAX_DEPLOY_PCT=0.5        # Max % of portfolio to deploy at once (0.5 = 50%)
DAILY_SPEND_CAP=999999    # Max currency to spend per day
